{
  "name": "star-table-workspace",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter play dev",
    "build": "pnpm --filter @star-table/core build",
    "build:v2": "pnpm --filter @star-table/table-v2 build",
    "lint": "eslint . --fix",
    "typecheck": "tsc --noEmit --composite false",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "element-plus": "^2.6.3",
    "eslint": "^10.1.0",
    "eslint-plugin-vue": "^10.8.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "sass": "^1.98.0",
    "typescript": "^5.4.5",
    "vue": "^3.4.21"
  },
  "lint-staged": {
    "*.{vue,js,ts,jsx,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,scss,html,json}": [
      "prettier --write"
    ]
  }
}
