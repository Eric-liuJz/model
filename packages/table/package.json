{
  "name": "@star-table/core",
  "version": "0.1.0",
  "description": "Enterprise-grade Vue 3 public table component based on Element Plus.",
  "main": "dist/star-table-core.umd.js",
  "module": "dist/star-table-core.es.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/star-table-core.es.js",
      "require": "./dist/star-table-core.umd.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "vue-tsc --noEmit && vite build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "element-plus": "^2.6.0",
    "vue": "^3.2.0"
  },
  "devDependencies": {
    "@types/lodash-es": "^4.17.12",
    "@types/sortablejs": "^1.15.9",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^20.8.9",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vitest": "^1.6.1",
    "vue-tsc": "^2.0.0"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@vueuse/core": "^14.2.1",
    "dayjs": "^1.11.20",
    "lodash-es": "^4.17.23",
    "sortablejs": "^1.15.7"
  }
}
